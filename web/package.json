{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:repair-ratings": "tsx scripts/recompute-skill-ratings.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run -c vitest.config.ts && vitest run -c vitest.component.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run -c vitest.component.config.ts",
    "playwright": "playwright test",
    "playwright:ui": "playwright test --ui",
    "test:all": "vitest run -c vitest.config.ts && vitest run -c vitest.component.config.ts && playwright test"
  },
  "dependencies": {
