# ClawPlay Web — Environment Variables
# Copy this to .env.local and fill in the values

# Default locale — must be set, allowed values: "zh" | "en"
NEXT_LOCALE=zh

# App base URL — required for OAuth callbacks (e.g. https://clawplay.example.com)
BASE_URL=https://your-domain.com

# SQLite database path (default: ../data/clawplay.db relative to web/)
DATABASE_URL=../data/clawplay.db

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# AES-256-GCM encryption key — generate with: openssl rand -hex 32
CLAWPLAY_SECRET_KEY=your-32-byte-secret-here

# Upstash Redis (Serverless) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Provider API Keys
# Ark (Volcengine) — https://console.volcengine.com/ark
ARK_API_KEY=your-ark-api-key

# Gemini (Google) — multi-provider fallback for LLM, image, vision
GEMINI_API_KEY=your-gemini-api-key

# Ark multi-key sharding — optional, only needed for high QPS
# Per-key quota (default: 500 RPM for image, 30000 RPM for vision)
ARK_KEY_QUOTA=500
ARK_VISION_KEY_QUOTA=30000

# TTS synthesis (Ark)
ARK_TTS_API_KEY=your-ark-tts-api-key

# LLM Provider: ark | gemini (default: ark)
LLM_PROVIDER=ark
LLM_MODEL_ARK=your-gemini-llm-model
LLM_MODEL_GEMINI=your-gemini-llm-model

# Vision Provider: ark | gemini (default: ark)
VISION_PROVIDER=ark
VISION_MODEL_ARK=your-ark-vision-model
VISION_MODEL_GEMINI=your-gemini-vision-model

# Image Provider: ark | gemini (default: ark)
IMAGE_PROVIDER=ark
IMAGE_MODEL_ARK=your-ark-image-model
IMAGE_MODEL_GEMINI=your-gemini-image-model

# Cron secret for key window reset endpoint
# CRON_SECRET=your-random-secret

# OAuth Providers
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# X (Twitter) OAuth — https://developer.twitter.com/en/docs/authentication/oauth2
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret

# Discord OAuth — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# WeChat OAuth
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_REDIRECT_BASE_URL=https://your-domain.com

# Aliyun SMS (for phone verification)
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=ClawPlay
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
