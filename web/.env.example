# ClawPlay Web — Environment Variables
# Copy this to .env.local and fill in the values

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# AES-256-GCM encryption key — generate with: openssl rand -hex 32
CLAWPLAY_SECRET_KEY=your-32-byte-secret-here

# Upstash Redis (Serverless) — https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Provider API Keys (for ability relay mode)
ARK_API_KEY=your-ark-api-key

# LLM Provider config
# LLM_PROVIDER: which LLM to use (ark | gemini)
# LLM_MODEL_ARK: Ark model ID (default: ep-20260124121016-r7b86)
# LLM_MODEL_GEMINI: Gemini model ID (default: gemini-3-flash-preview)
LLM_PROVIDER=ark
LLM_MODEL_ARK=ep-20260124121016-r7b86
LLM_MODEL_GEMINI=gemini-3-flash-preview

# Image Provider config
# IMAGE_PROVIDER: which image provider to use (ark | gemini)
# IMAGE_MODEL_ARK: Ark image model ID (default: ep-20260307174559-w6lfl)
# IMAGE_MODEL_GEMINI: Gemini image model ID (default: gemini-3.1-flash-image-preview)
IMAGE_PROVIDER=ark
IMAGE_MODEL_ARK=ep-20260307174559-w6lfl
IMAGE_MODEL_GEMINI=gemini-3.1-flash-image-preview

# Audit log path (optional)
# AUDIT_LOG_PATH=../data/audit.jsonl
