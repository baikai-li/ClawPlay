    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "jszip": "^3.10.1",
    "next": "14.2.35",
